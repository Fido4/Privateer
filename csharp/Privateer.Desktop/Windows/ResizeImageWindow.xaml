<Window x:Class="Privateer.Desktop.Windows.ResizeImageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Resize Image"
        Icon="/Assets/PrivateerAppIcon.ico"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource PrimaryTextBrush}"
        Width="440"
        Height="360"
        MinWidth="440"
        MinHeight="360"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Style="{DynamicResource SectionHeadingStyle}" Text="Resize Image" />

        <StackPanel Grid.Row="2">
            <TextBlock Style="{DynamicResource CaptionStyle}" Text="Width" />
            <TextBox x:Name="WidthTextBox" Margin="0,8,0,0" TextChanged="DimensionTextBox_TextChanged" />
        </StackPanel>

        <StackPanel Grid.Row="4">
            <TextBlock Style="{DynamicResource CaptionStyle}" Text="Height" />
            <TextBox x:Name="HeightTextBox" Margin="0,8,0,0" TextChanged="DimensionTextBox_TextChanged" />
        </StackPanel>

        <CheckBox Grid.Row="6"
                  x:Name="MaintainAspectRatioCheckBox"
                  Content="Maintain aspect ratio"
                  IsChecked="True"
                  Checked="MaintainAspectRatioCheckBox_Changed"
                  Unchecked="MaintainAspectRatioCheckBox_Changed" />

        <WrapPanel Grid.Row="8"
                   Margin="0,6,0,0"
                   HorizontalAlignment="Right">
            <Button Margin="0,0,10,0"
                    Style="{DynamicResource GhostButtonStyle}"
                    Content="Cancel"
                    Click="CancelButton_Click" />
            <Button Content="Apply"
                    Click="ApplyButton_Click" />
        </WrapPanel>
    </Grid>
</Window>
